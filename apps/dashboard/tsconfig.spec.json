{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "../../dist/out-tsc",
    "types": ["jest", "node"],
    "module": "ES2022",
    "target": "ES2022",
    "lib": ["ES2022", "dom"],
    "esModuleInterop": true,
    "isolatedModules": true,
    "emitDecoratorMetadata": false
  },
  "files": ["src/test-setup.ts"],
  "include": [
    "jest.config.cts",
    "src/**/*.spec.ts",
    "src/**/*.test.ts",
    "src/**/*.d.ts"
  ]
}
